{
  "manifest_version": 3,
  "name": "Lead Vetter",
  "version": "1.0.0",
  "description": "Automate lead vetting workflows on heyreach.io",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://app.heyreach.io/*",
    "https://www.linkedin.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://app.heyreach.io/*"],
      "js": ["content/content.js"]
    }
  ]
}
